+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Expert Router (MoE)
+# ═══════════════════════════════════════════════════════════════
+er:
+  id: "expert_router"
+  name: "Expert Router (MoE Gating)"
+  type: ROUTER
+  
+  T: 0.001              # 1ms на routing decision
+  P_err: 0.001          # 0.1% ошибок
+  P_rec: 1.0            # 100% восстановлений (stateless)
+  D: 0.0                # Нет штрафа
+  
+  in_ML: []
+  mod_ML: [ROUTING_FAIL]
+  out_ML: {ROUTING_FAIL → "decode_pool"}
+  
+  aggregation_type: SUM

+## 2. Алгоритм RSA для IR-симулятора
+
+### 2.1. Классический RSA (Hornberger-Spear)
+
+```python
+def rsa_analysis(X_u, Y_u, param_names, DA_target=0.99):
+    """
+    Regional Sensitivity Analysis.
+    
+    Args:
+        X_u: [N × k] матрица параметров (из PAWN unconditional)
+        Y_u: [N] вектор DA (из PAWN unconditional)
+        param_names: список имён параметров
+        DA_target: порог успеха
+    
+    Returns:
+        RSA результаты для каждого параметра
+    """
+    N, k = X_u.shape
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 1: Разделение на Behavioral / Non-behavioral
+    # ═══════════════════════════════════════════════════════════
+    behavioral_mask = Y_u >= DA_target
+    non_behavioral_mask = Y_u < DA_target
+    
+    n_behavioral = np.sum(behavioral_mask)
+    n_non_behavioral = np.sum(non_behavioral_mask)
+    
+    # Проверка баланса групп
+    if n_behavioral < 50 or n_non_behavioral < 50:
+        print(f"⚠️ WARNING: Несбалансированные группы!")
+        print(f"   Behavioral: {n_behavioral}, Non-behavioral: {n_non_behavioral}")
+        print(f"   Рекомендация: изменить DA_target или расширить диапазоны")
+    
+    X_behavioral = X_u[behavioral_mask]
+    X_non_behavioral = X_u[non_behavioral_mask]
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 2: KS-тест для каждого параметра
+    # ═══════════════════════════════════════════════════════════
+    results = {}
+    
+    for i, param_name in enumerate(param_names):
+        # Значения параметра в каждой группе
+        x_behav = X_behavioral[:, i]
+        x_non_behav = X_non_behavioral[:, i]
+        
+        # KS-статистика и p-value
+        ks_stat, p_value = scipy.stats.ks_2samp(x_behav, x_non_behav)
+        
+        # Направление эффекта
+        mean_behav = np.mean(x_behav)
+        mean_non_behav = np.mean(x_non_behav)
+        
+        if mean_behav < mean_non_behav:
+            direction = 'LOWER_IS_BETTER'
+            risk_zone = f'{param_name} > {np.percentile(x_behav, 75):.4f}'
+        else:
+            direction = 'HIGHER_IS_BETTER'
+            risk_zone = f'{param_name} < {np.percentile(x_behav, 25):.4f}'
+        
+        # Найти "критический порог" — значение, разделяющее группы
+        # (медиана non-behavioral как приближение)
+        critical_threshold = np.median(x_non_behav)
+        
+        results[param_name] = {
+            'KS': ks_stat,
+            'p_value': p_value,
+            'significant': p_value < 0.05,
+            'direction': direction,
+            'mean_behavioral': mean_behav,
+            'mean_non_behavioral': mean_non_behav,
+            'critical_threshold': critical_threshold,
+            'risk_zone': risk_zone,
+            'recommendation': f"Держать {param_name} {'<' if direction == 'LOWER_IS_BETTER' else '>'} {critical_threshold:.4f}"
+        }
+    
+    return {
+        'parameters': results,
+        'n_behavioral': n_behavioral,
+        'n_non_behavioral': n_non_behavioral,
+        'DA_target': DA_target
+    }
+```

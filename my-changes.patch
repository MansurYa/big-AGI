+  P_rec: float                # Вероятность успешного восстановления [0, 1]
+  
+  # Штрафы (РАЗДЕЛЕНЫ)
+  D_delay: float              # Доп. время при задержке (сек)
+  D_recovery: float           # Время восстановления (сек)
+  

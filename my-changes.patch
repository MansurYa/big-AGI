+### 4. Параметры блоков
+
+```yaml
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: API Gateway
+# ═══════════════════════════════════════════════════════════════
+gw:
+  id: "api_gateway"
+  name: "API Gateway (AsyncLLM)"
+  type: GATEWAY
+  # Базовые параметры
+  T:0.005# 5ms на обработку запроса
+  P_err: 0.001          # 0.1% ошибок (rate limiting, auth)
+  P_rec: 0.99           # 99% восстановлений
+  D: 0.5                # 500ms на retry
+  
+  # Структурные параметры
+  in_ML: []             # Нет входящих ошибок (это вход)
+  mod_ML: [RATE_LIMIT, AUTH_FAIL]
+  out_ML: {RATE_LIMIT → "source", AUTH_FAIL → "source"}
+  
+  # Агрегация
+  aggregation_type: SUM
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Scheduler
+# ═══════════════════════════════════════════════════════════════
+sch:
+  id: "scheduler"
+  name: "Global Scheduler"
+  type: SCHEDULER
+  
+  T: 0.002              # 2ms на планирование
+  P_err: 0.005          # 0.5% ошибок (перегрузка)
+  P_rec: 0.95           # 95% восстановлений
+  D: 1.0                # 1s на перепланирование
+  
+  in_ML:
+    - {error_type: PREFILL_FAIL, action: DELAY, params: {delay: 0.5}}
+    - {error_type: DECODE_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}
+  mod_ML: [QUEUE_FULL, TIMEOUT]
+  out_ML: {QUEUE_FULL → "api_gateway", TIMEOUT → "api_gateway"}
+  
+  aggregation_type: QUEUE  # Учитывает очередь!
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Prefill Pool
+# ═══════════════════════════════════════════════════════════════
+pf:
+  id: "prefill_pool"
+  name: "Prefill Stage (N instances)"
+  type: COMPUTE
+  
+  T: 0.5                # 500ms среднее (зависит от длины промпта)
+  P_err: 0.02# 2% ошибок (OOM, compute fail)
+  P_rec: 0.9            # 90% восстановлений
+  D: 2.0                # 2s на восстановление
+  
+  in_ML:
+    - {error_type: SCHEDULER_TIMEOUT, action: RECOVER, params: {}}mod_ML: [OOM, COMPUTE_FAIL]
+  out_ML: {OOM → "scheduler", COMPUTE_FAIL → "scheduler"}
+  
+  aggregation_type: SUM
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: KV-Transfer
+# ═══════════════════════════════════════════════════════════════
+kv:
+  id: "kv_transfer"
+  name: "KV-Cache Transfer (Network)"
+  type: NETWORK
+  
+  T: 0.1                # 100ms базовое (зависит от размера)
+  P_err: 0.005          # 0.5% сетевых ошибок
+  P_rec: 0.99           # 99% восстановлений (retry)
+  D: 0.2                # 200ms на retry
+  
+  in_ML:
+    - {error_type: PREFILL_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}
+  mod_ML: [NETWORK_FAIL, TIMEOUT]
+  out_ML: {NETWORK_FAIL → "prefill_pool", TIMEOUT → "scheduler"}
+  
+  aggregation_type: SUM
+  
+  # Дополнительно для сети
+  bandwidth: 100.0      # 100 GB/s (NVLink)
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Decode Pool
+# ═══════════════════════════════════════════════════════════════
+dc:
+  id: "decode_pool"
+  name: "Decode Stage (M instances)"
+  type: COMPUTE
+  
+  T: 0.02               # 20ms на токен (× количество токенов)
+  P_err: 0.03           # 3% ошибок (OOM — основная причина)
+  P_rec: 0.85           # 85% восстановлений
+  D: 3.0                # 3s на восстановление (потеря KV-Cache!)
+  
+  in_ML:
+    - {error_type: KV_TRANSFER_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}

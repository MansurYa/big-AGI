+        cv_threshold_high = 1.5  # вместо 1.0
+        note = 'P_err: повышенный CV ожидаем из-за fallback-эффекта'
+    else:
+        cv_threshold_low = 0.5
+        cv_threshold_high = 1.0
+        note = None
+    
+    if cv > cv_threshold_high:
+        reliability = 'LOW'
+    elif cv > cv_threshold_low:
+        reliability = 'MEDIUM'
+    else:
+        reliability = 'HIGH'
+    
+    return {
+        'reliability': reliability,
+        'cv': cv,
+        'cv_thresholds': (cv_threshold_low, cv_threshold_high),
+        'note': note
+    }

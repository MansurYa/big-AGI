+  P_rec: 0.95           # 95% восстановлений
+  D: 1.0                # 1s на перепланирование
+  
+  in_ML:
+    - {error_type: PREFILL_FAIL, action: DELAY, params: {delay: 0.5}}
+    - {error_type: DECODE_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}
+  mod_ML: [QUEUE_FULL, TIMEOUT]
+  out_ML: {QUEUE_FULL → "api_gateway", TIMEOUT → "api_gateway"}
+  
+  aggregation_type: QUEUE  # Учитывает очередь!
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Prefill Pool
+# ═══════════════════════════════════════════════════════════════

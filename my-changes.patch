+## 4. Интеграция PAWN + RSA (один проход)
+
+### 4.1. Использование unconditional sample для RSA
+
+```python
+def integrated_PAWN_RSA(Y_u, X_u, DA_target=0.99):
+    """
+    RSA анализ на той же выборке, что и PAWN
+    """
+    # Разделить на behavioral / non-behavioral
+    behavioral_mask = Y_u >= DA_target
+    non_behavioral_mask = Y_u < DA_target
+    
+    X_behavioral = X_u[behavioral_mask]
+    X_non_behavioral = X_u[non_behavioral_mask]
+    
+    RSA_results = {}
+    
+    for i, param_name in enumerate(parameters.keys()):
+        # CDF параметра для успешных прогонов
+        F_behavioral = empirical_cdf(X_behavioral[:, i])
+        
+        # CDF параметра для неуспешных прогонов
+        F_non_behavioral = empirical_cdf(X_non_behavioral[:, i])
+        
+        # KS-расстояние между ними
+        KS = kolmogorov_smirnov_distance(F_behavioral, F_non_behavioral)
+        
+        RSA_results[param_name] = {
+            'KS': KS,
+            'behavioral_mean': np.mean(X_behavioral[:, i]),
+            'non_behavioral_mean': np.mean(X_non_behavioral[:, i]),
+            'direction': 'higher_is_worse' if behavioral_mean < non_behavioral_mean else 'lower_is_worse'
+        }
+    
+    return RSA_results
+```

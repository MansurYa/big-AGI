+## 5. Интеграция PAWN + RSA: единый pipeline
+
+### 5.1. Объединённый алгоритм
+
+```python
+def integrated_pawn_rsa(parameters, simulator, N_u=3000, S=10, N_c=200, DA_target=0.99):
+    """
+    Интегрированный анализ PAWN + RSA.
+    
+    Одна выборка — два анализа.
+    """
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 1: Unconditional Sampling (общий для PAWN и RSA)
+    # ═══════════════════════════════════════════════════════════
+    X_u = latin_hypercube_sample(parameters, N_u)
+    Y_u = np.array([simulator(x) for x in X_u])
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 2: PAWN Analysis
+    # ═══════════════════════════════════════════════════════════
+    pawn_results = pawn_conditional_analysis(X_u, Y_u, parameters, S, N_c, simulator)
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 3: RSA Analysis (на той же выборке!)
+    # ═══════════════════════════════════════════════════════════
+    rsa_results = rsa_risk_zones(X_u, Y_u, list(parameters.keys()), DA_target)
+    
+    # ═══════════════════════════════════════════════════════════
+    # STEP 4: Объединённый отчёт
+    # ═══════════════════════════════════════════════════════════
+    combined_report = {
+        'pawn': pawn_results,
+        'rsa': rsa_results,
+        'ranking': create_combined_ranking(pawn_results, rsa_results),
+        'recommendations': generate_recommendations(pawn_results, rsa_results)
+    }
+    
+    return combined_report
+
+
+def create_combined_ranking(pawn_results, rsa_results):
+    """
+    Объединённое ранжирование параметров.
+    
+    PAWN даёт "силу влияния", RSA даёт "практическую значимость".
+    """
+    ranking = []
+    
+    for param_name in pawn_results.keys():
+        pawn_index = pawn_results[param_name]['median']
+        rsa_ks = rsa_results['parameters'][param_name]['KS']
+        
+        # Комбинированный score (среднее геометрическое)
+        combined_score = np.sqrt(pawn_index * rsa_ks)
+        
+        ranking.append({
+            'parameter': param_name,
+            'pawn_index': pawn_index,
+            'rsa_ks': rsa_ks,
+            'combined_score': combined_score,
+            'recommendation': rsa_results['parameters'][param_name]['recommendation']
+        })
+    
+    # Сортировка по combined_score
+    ranking.sort(key=lambda x: x['combined_score'], reverse=True)
+    
+    return ranking
+```

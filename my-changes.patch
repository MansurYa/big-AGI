+## 2.0.2: DA Range Validation
+
+### Что проверяем
+
+SA-методы работают корректно, когда выход (DA) имеет **достаточную вариацию**:
+- DA ≈ 1.0 для всех точек → Все EE ≈ 0, все KS ≈ 0
+- DA ≈ 0.0 для всех точек → Система сломана, SA бессмысленен
+- DA бимодальна (0.3 или 0.99) → Sobol может быть нестабилен
+
+### Алгоритм проверки
+
+```python
+def da_range_validation(Y_sample):
+    """
+    Проверка диапазона и распределения DA.
+    
+    Args:
+        Y_sample: массив DA из correlation_check (N=500 значений)
+    
+    Returns:
+        statistics: описательная статистика
+        distribution_type: 'normal', 'skewed', 'bimodal', 'degenerate'
+        warnings: список проблем
+        recommendation: что делать
+    """
+    
+    da_min = np.min(Y_sample)
+    da_max = np.max(Y_sample)
+    da_mean = np.mean(Y_sample)
+    da_std = np.std(Y_sample)
+    da_cv = da_std / da_mean if da_mean > 0 else float('inf')
+    
+    # Квантили
+    da_p05 = np.percentile(Y_sample, 5)
+    da_p95 = np.percentile(Y_sample, 95)
+    
+    warnings = []
+    
+    # Проверка 1: DA слишком высокая (система "идеальна")
+    if da_p05 > 0.95:
+        warnings.append({
+            'type': 'DA_TOO_HIGH',
+            'message': f'DA > 0.95 для 95% точек (p05={da_p05:.3f})',
+            'severity': 'HIGH',
+            'action': 'Расширить диапазоны параметров (увеличить P_err, T)'
+        })
+    
+    # Проверка 2: DA слишком низкая (система "сломана")
+    if da_p95 < 0.5:
+        warnings.append({
+            'type': 'DA_TOO_LOW',
+            'message': f'DA < 0.5 для 95% точек (p95={da_p95:.3f})',
+            'severity': 'HIGH',
+            'action': 'Сузить диапазоны параметров (уменьшить P_err, T)'
+        })
+    
+    # Проверка 3: DA не варьируется (все значения одинаковы)
+    if da_cv < 0.01:
+        warnings.append({
+            'type': 'DA_NO_VARIATION',
+            'message': f'CV(DA) = {da_cv:.4f} < 0.01',
+            'severity': 'CRITICAL',
+            'action': 'SA невозможен. Расширить диапазоны параметров.'
+        })
+    
+    # Проверка 4: DA бимодальна (два пика)
+    # Простая эвристика: проверить, есть ли "провал" в середине гистограммы
+    hist, bins = np.histogram(Y_sample, bins=20)
+    mid_bins = hist[5:15]  # Средняя часть
+    if np.min(mid_bins) < 0.1 * np.max(hist):
+        warnings.append({
+            'type': 'DA_BIMODAL',
+            'message': 'DA имеет бимодальное распределение',
+            'severity': 'MEDIUM',
+            'action': 'Sobol может быть нестабилен. Использовать PAWN + RSA.'
+        })
+    
+    # Определить тип распределения
+    if len(warnings) > 0 and any(w['type'] == 'DA_NO_VARIATION' for w in warnings):
+        distribution_type = 'degenerate'
+    elif any(w['type'] == 'DA_BIMODAL' for w in warnings):
+        distribution_type = 'bimodal'
+    elif abs(da_mean - 0.5) > 0.3:  # Сильно смещено к 0 или 1
+        distribution_type = 'skewed'
+    else:
+        distribution_type = 'normal'
+    
+    # Рекомендация
+    if len(warnings) == 0:
+        recommendation = "PROCEED: DA в допустимом диапазоне"
+    elif any(w['severity'] == 'CRITICAL' for w in warnings):
+        recommendation = "BLOCK: SA невозможен до исправления диапазонов"
+    elif any(w['severity'] == 'HIGH' for w in warnings):
+        recommendation = "ADJUST: Скорректировать диапазоны параметров"
+    else:
+        recommendation = "CAUTION: Продолжить с осторожностью"
+    
+    return {
+        'statistics': {
+            'min': da_min, 'max': da_max, 'mean': da_mean,
+            'std': da_std, 'cv': da_cv, 'p05': da_p05, 'p95': da_p95
+        },
+        'distribution_type': distribution_type,
+        'warnings': warnings,
+        'recommendation': recommendation
+    }
+```
+
+### Пороги и интерпретация
+
+```
+┌─────────────────────────────────────────────────────────────────────────┐
+│                    DA RANGE THRESHOLDS                                 │
+├─────────────────────────────────────────────────────────────────────────┤
+│                                                                         │
+│  ИДЕАЛЬНЫЙ ДИАПАЗОН:                                                   │
+│  ├─ DA_mean ∈ [0.7, 0.95]  — типичный SLA compliance                  │
+│  ├─ DA_p05 > 0.3           — не все провалы                           │
+│  ├─ DA_p95 < 0.99          — не все успехи                            │
+│  └─ CV(DA) ∈ [0.05, 0.3]   — достаточная вариация                     │
+│                                                                         │
+│  ПРОБЛЕМНЫЕ СЛУЧАИ:                                                    │
+│  ├─ DA_p05 > 0.95  → 🔴 Система "идеальна", SA не информативен        │
+│  ├─ DA_p95 < 0.5   → 🔴 Система "сломана", SA не информативен         │
+│  ├─ CV(DA) < 0.01  → 🔴 Нет вариации, SA невозможен                   │
+│  └─ Бимодальность  → 🟡 Sobol нестабилен, использовать PAWN           │
+│                                                                         │
+└─────────────────────────────────────────────────────────────────────────┘
+```

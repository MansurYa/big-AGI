+  P_err: 0.02# 2% ошибок (OOM, compute fail)
+  P_rec: 0.9            # 90% восстановлений
+  D: 2.0                # 2s на восстановление
+  
+  in_ML:
+    - {error_type: SCHEDULER_TIMEOUT, action: RECOVER, params: {}}mod_ML: [OOM, COMPUTE_FAIL]
+  out_ML: {OOM → "scheduler", COMPUTE_FAIL → "scheduler"}
+  
+  aggregation_type: SUM
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: KV-Transfer
+# ═══════════════════════════════════════════════════════════════
+kv:
+  id: "kv_transfer"
+  name: "KV-Cache Transfer (Network)"
+  type: NETWORK
+  
+  T: 0.1                # 100ms базовое (зависит от размера)
+  P_err: 0.005          # 0.5% сетевых ошибок
+  P_rec: 0.99           # 99% восстановлений (retry)
+  D: 0.2                # 200ms на retry
+  
+  in_ML:
+    - {error_type: PREFILL_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}
+  mod_ML: [NETWORK_FAIL, TIMEOUT]
+  out_ML: {NETWORK_FAIL → "prefill_pool", TIMEOUT → "scheduler"}
+  
+  aggregation_type: SUM
+  
+  # Дополнительно для сети
+  bandwidth: 100.0      # 100 GB/s (NVLink)
+
+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Decode Pool
+# ═══════════════════════════════════════════════════════════════
+dc:
+  id: "decode_pool"
+  name: "Decode Stage (M instances)"
+  type: COMPUTE
+  
+  T: 0.02               # 20ms на токен (× количество токенов)
+  P_err: 0.03           # 3% ошибок (OOM — основная причина)
+  P_rec: 0.85           # 85% восстановлений
+  D: 3.0                # 3s на восстановление (потеря KV-Cache!)
+  
+  in_ML:
+    - {error_type: KV_TRANSFER_FAIL, action: ROLLBACK, params: {target: "prefill_pool"}}

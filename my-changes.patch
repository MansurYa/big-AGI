+```python
+def PAWN_for_IR(parameters, simulator, N_u, S, N_c):
+    """
+    PAWN analysis для IR-симулятора доступности
+    """
+    k = len(parameters)
+    
+    # ═══════════════════════════════════════════════════════
+    # STEP 1: Unconditional Sampling
+    # ═══════════════════════════════════════════════════════
+    X_u = latin_hypercube_sample(parameters, N_u)  # [N_u × k]
+    Y_u = np.array([simulator(x, N_requests) for x in X_u])  # DA values
+    
+    # Построить эмпирическую CDF
+    F_unconditional = empirical_cdf(Y_u)
+    
+    # ═══════════════════════════════════════════════════════
+    # STEP 2: Conditional Sampling для каждого параметра
+    # ═══════════════════════════════════════════════════════
+    PAWN_indices = {}
+    
+    for i, param_name in enumerate(parameters.keys()):
+        param_range = parameters[param_name]
+        
+        # Разбить диапазон на S слайдов
+        slides = np.linspace(param_range[0], param_range[1], S + 1)
+        
+        KS_values = []
+        
+        for s in range(S):
+            # Фиксировать X_i в центре слайда
+            x_i_fixed = (slides[s] + slides[s+1]) / 2
+            
+            # Сгенерировать conditional samples для остальных параметров
+            X_c = latin_hypercube_sample(
+                {k: v for k, v in parameters.items() if k != param_name},
+                N_c
+            )
+            
+            # Вставить фиксированное значение X_i
+            X_c_full = insert_fixed_param(X_c, i, x_i_fixed)
+            
+            # Запустить симулятор
+            Y_c = np.array([simulator(x, N_requests) for x in X_c_full])
+            
+            # Построить условную CDF
+            F_conditional = empirical_cdf(Y_c)
+            
+            # KS-статистика
+            KS = kolmogorov_smirnov_distance(F_unconditional, F_conditional)
+            KS_values.append(KS)
+        
+        # Агрегировать KS по слайдам
+        PAWN_indices[param_name] = {
+            'median': np.median(KS_values),
+            'mean': np.mean(KS_values),
+            'max': np.max(KS_values),
+            'cv': np.std(KS_values) / np.mean(KS_values),  # Коэф. вариации
+            'raw': KS_values
+        }
+    
+    return PAWN_indices, Y_u  # Y_u для RSA
+```
+
+### 2.3. Вычислительная стоимость
+
+```
+Unconditional:  N_u = 3000 прогонов
+Conditional:    k × S × N_c = 6 × 10 × 200 = 12000 прогонов
+─────────────────────────────────────────────────────────
+ИТОГО:          15000 прогонов
+
+При 10 сек/прогон: ~42 часа
+При 1 сек/прогон:  ~4 часа
+```
+
+**Оптимизация:** Можно параллелить — прогоны независимы.

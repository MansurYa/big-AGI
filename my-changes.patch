+# ═══════════════════════════════════════════════════════════════
+# БЛОК: Expert Groups (MoE) — КРИТИЧНО: MAX агрегация!
+# ═══════════════════════════════════════════════════════════════
+eg:
+  id: "expert_groups"
+  name: "Expert Groups (8 active of 256)"
+  type: COMPUTE
+  
+  T: 0.015              # 15ms среднее на эксперта
+  P_err: 0.02           # 2% ошибок (один эксперт недоступен)
+  P_rec: 0.9            # 90% восстановлений
+  D: 1.0                # 1s на переключение на резервного
+  
+  in_ML:
+    - {error_type: ROUTING_FAIL, action: RECOVER, params: {}}
+  mod_ML: [EXPERT_UNAVAIL, EXPERT_TIMEOUT]
+  out_ML: {EXPERT_UNAVAIL → "expert_router"}

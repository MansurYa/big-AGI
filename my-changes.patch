+### 2.2. Расширенный RSA с зонами риска
+
+```python
+def rsa_risk_zones(X_u, Y_u, param_names, DA_target=0.99):
+    """
+    RSA с детальным анализом зон риска.
+    """
+    results = rsa_analysis(X_u, Y_u, param_names, DA_target)
+    
+    for i, param_name in enumerate(param_names):
+        x_values = X_u[:, i]
+        
+        # Разбить диапазон параметра на 10 бинов
+        bins = np.linspace(np.min(x_values), np.max(x_values), 11)
+        bin_centers = (bins[:-1] + bins[1:]) / 2
+        
+        # Для каждого бина: доля non-behavioral
+        failure_rates = []
+        for j in range(10):
+            mask = (x_values >= bins[j]) & (x_values < bins[j+1])
+            if np.sum(mask) > 0:
+                failure_rate = np.mean(Y_u[mask] < DA_target)
+            else:
+                failure_rate = np.nan
+            failure_rates.append(failure_rate)
+        
+        # Найти "зону риска" — бины с failure_rate > 50%
+        risk_bins = [bin_centers[j] for j in range(10) 
+                     if not np.isnan(failure_rates[j]) and failure_rates[j] > 0.5]
+        
+        if len(risk_bins) > 0:
+            risk_zone_min = np.min(risk_bins)
+            risk_zone_max = np.max(risk_bins)
+            results['parameters'][param_name]['risk_zone_detailed'] = {
+                'min': risk_zone_min,
+                'max': risk_zone_max,
+                'description': f'{param_name} ∈ [{risk_zone_min:.4f}, {risk_zone_max:.4f}]'
+            }
+        
+        results['parameters'][param_name]['failure_rates'] = {
+            'bins': bin_centers.tolist(),
+            'rates': failure_rates
+        }
+    
+    return results
+```
